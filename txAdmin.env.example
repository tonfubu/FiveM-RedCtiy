# ============================================================
#   txAdmin.env.example  --  copy to txAdmin.env (chmod 600, gitignored)
#   Loaded by fivem-redcity.service via EnvironmentFile=
#   Docs: <artifact>/citizen/system_resources/monitor/docs/env-config.md
# ============================================================

# txData location + web panel
TXHOST_DATA_PATH=/opt/fivem-redcity/txData
TXHOST_TXA_PORT=40120
TXHOST_INTERFACE=0.0.0.0
TXHOST_IGNORE_DEPRECATED_CONFIGS=true
TXHOST_PROVIDER_NAME=RedCity

# Auto-create master admin on first boot (no PIN needed).
# Format: username::<bcrypt $2b$ hash>
# Generate hash:  htpasswd -bnBC 11 "" 'YourPassword' | tr -d ':\n' | sed 's/^$2y$/$2b$/'
TXHOST_DEFAULT_ACCOUNT=redcityadmin::CHANGE_ME_BCRYPT_HASH

# Deployer auto-fill defaults (used only when deploying a new server)
TXHOST_DEFAULT_DBHOST=10.10.10.205
TXHOST_DEFAULT_DBPORT=3306
TXHOST_DEFAULT_DBUSER=DB_USER
TXHOST_DEFAULT_DBPASS=CHANGE_ME
TXHOST_DEFAULT_DBNAME=redcity_esx
TXHOST_DEFAULT_CFXKEY=CHANGE_ME
