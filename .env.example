# ============================================================
#   .env.example  --  reference for the database connection.
#   Copy to .env and fill in real values. .env is gitignored.
#   NOTE: FiveM itself reads the DB config from
#         server-data/secrets.cfg (server.cfg execs it).
#         This file is documentation / for helper scripts.
# ============================================================
DB_HOST=10.10.10.205
DB_PORT=3306
DB_NAME=redcity_esx
DB_USER=redpotiondb
DB_PASSWORD=CHANGE_ME

# oxmysql connection string (semicolon format - put '@' literally)
MYSQL_CONNECTION_STRING=server=10.10.10.205;uid=redpotiondb;password=CHANGE_ME;database=redcity_esx;charset=utf8mb4

# FiveM license key from https://keymaster.fivem.net
SV_LICENSE_KEY=CHANGE_ME
