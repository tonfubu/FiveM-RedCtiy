# ===== Secrets =====
server-data/secrets.cfg
.env
*.key
*.pem

# ===== Real config (may contain admin identifiers) =====
server-data/server.cfg

# ===== FiveM artifact (downloaded, not source) =====
server/

# ===== Resources: ignore third-party/binary, but KEEP our own source resources =====
server-data/resources/*
!server-data/resources/\[redcity\]/

# ===== Runtime / cache / logs =====
server-data/cache/
server-data/db/
logs/
*.log

# ===== Backups & DB dumps (may contain real player data) =====
backups/
*.sql
*.sql.gz
*.dump

# ===== OS / editor junk =====
.DS_Store
Thumbs.db
*.swp

# FXServer console history
server-data/.replxx_history
*.replxx_history

# txAdmin data (credentials/secrets)
txData/

# txAdmin env (admin hash, DB pass, cfx key)
txAdmin.env
