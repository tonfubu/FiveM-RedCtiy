# ============================================================
#   secrets.cfg.example  --  copy to secrets.cfg and fill in real values
#   secrets.cfg is gitignored and must NEVER be committed.
# ============================================================

# DB connection string. URL-encode special chars in the password
# (e.g. '@' -> '%40', '#' -> '%23').
set mysql_connection_string "mysql://DB_USER:DB_PASSWORD@DB_HOST/redcity_esx?charset=utf8mb4&waitForConnections=true"

# Rockstar/FiveM license key from https://keymaster.fivem.net
sv_licenseKey "CHANGE_ME"

# Optional - Steam Web API key from https://steamcommunity.com/dev/apikey
set steam_webApiKey ""
