# ============================================================
#   FiveM RedCity - ESX Legacy - server.cfg
#   Server: 10.10.10.163  | DB: 10.10.10.205 / redcity_esx
#   NOTE: Secrets (DB connection string + license key) live in
#         secrets.cfg which is executed below and is NOT committed.
# ============================================================

# ---------- Endpoints ----------
endpoint_add_tcp "0.0.0.0:30120"
endpoint_add_udp "0.0.0.0:30120"
sv_endpointPrivacy true

# ---------- Server identity ----------
sv_hostname "FiveM RedCity ESX Legacy"
sets sv_projectName "FiveM RedCity"
sets sv_projectDesc "RedCity ESX Legacy Server"
sets tags "esx, esx legacy, roleplay, thai"
sets locale "th-TH"
sv_maxclients 48

# ---------- Game build (mp2023_02 - The Chop Shop) ----------
sv_enforceGameBuild 3095

# ---------- OneSync ----------
set onesync on

# ---------- System chat ----------
set resources_useSystemChat true

# ---------- ESX locale ----------
setr esx:locale "en"

# ---------- oxmysql ----------
set mysql_ui false

# ============================================================
#   Secrets (DB connection string + sv_licenseKey + steam key)
#   Real values are stored ONLY on the server in secrets.cfg.
# ============================================================
exec secrets.cfg

# ============================================================
#   Permissions / Admin
# ============================================================
add_ace group.admin command allow
add_ace group.admin command.quit deny
add_principal group.admin group.user
add_ace resource.es_extended command.add_ace allow
add_ace resource.es_extended command.add_principal allow
add_ace resource.es_extended command.remove_principal allow
add_ace resource.es_extended command.stop allow

# >>> Replace CHANGE_ME with your real Rockstar license identifier <<<
add_principal identifier.license:CHANGE_ME group.admin

# ============================================================
#   Resource start order
# ============================================================
# --- Database driver ---
ensure oxmysql

# --- Default system / managers ---
# NOTE: do NOT start mapmanager / fivem / basic-gamemode -- es_extended
#       blocks them (it uses its own spawn + multicharacter system).
ensure baseevents
ensure chat
ensure spawnmanager
ensure sessionmanager
ensure hardcap
ensure rconlog

# --- ESX core (es_extended + menus + identity + skin + inventory + multichar) ---
ensure es_extended
ensure [core]

# --- ESX addons (basic stable set) ---
ensure esx_addonaccount
ensure esx_addoninventory
ensure esx_datastore
ensure esx_society
ensure esx_status
ensure esx_basicneeds
ensure esx_optionalneeds
ensure esx_billing
ensure esx_license
ensure esx_jobs
ensure esx_ambulancejob
ensure esx_vehicleshop
ensure esx_garage
